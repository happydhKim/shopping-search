{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Cluster Status",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "elasticsearch_cluster_health_status{color=\"green\"}", "legendFormat": "green" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "RED" }, "1": { "text": "GREEN" } } }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Number of Nodes",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "elasticsearch_cluster_health_number_of_nodes" }
      ]
    },
    {
      "type": "stat",
      "title": "Active Shards",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "elasticsearch_cluster_health_active_shards" }
      ]
    },
    {
      "type": "stat",
      "title": "Unassigned Shards",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "elasticsearch_cluster_health_unassigned_shards" }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used % per node",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "elasticsearch_jvm_memory_used_bytes{area=\"heap\"} / elasticsearch_jvm_memory_max_bytes{area=\"heap\"} * 100",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "type": "timeseries",
      "title": "GC Collection Time (Old + Young)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(elasticsearch_jvm_gc_collection_seconds_sum[1m])",
          "legendFormat": "{{name}} {{gc}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Search Rate (req/s)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(elasticsearch_indices_search_query_total[1m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Indexing Rate (docs/s)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(elasticsearch_indices_indexing_index_total[1m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Segment Memory (Heap occupied by segments)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "elasticsearch_indices_segments_memory_bytes",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries",
      "title": "Thread Pool Rejected",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "elasticsearch_thread_pool_rejected_count",
          "legendFormat": "{{name}} {{type}}"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["elasticsearch", "phase1"],
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "",
  "title": "ES Phase 1 — Cluster Overview",
  "uid": "es-phase1-overview",
  "version": 1
}

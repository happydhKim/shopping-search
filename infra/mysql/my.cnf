# MySQL client/server charset 고정
#
# Why:
#   MySQL 8.0 공식 이미지의 기본 my.cnf는 [client]/[mysql] 섹션에 default-character-set을 지정하지 않는다.
#   이 경우 mysql CLI가 컨테이너의 OS locale(C locale → latin1)로 커넥션 charset을 잡아
#   docker-entrypoint-initdb.d/*.sql 실행 시점에 UTF-8 한글 바이트가 이중 인코딩되어 저장되는
#   Mojibake 사고가 발생한다 (docs/incidents/2026-04-17-korean-encoding-fix.md).
#
# 이 파일은 /etc/mysql/conf.d/charset.cnf 로 마운트되며, /etc/my.cnf 의 !includedir 이 자동으로 읽는다.

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4

[mysqld]
character-set-server              = utf8mb4
collation-server                  = utf8mb4_0900_ai_ci
init-connect                      = 'SET NAMES utf8mb4'
# 클라이언트가 자체 charset을 advertise 해도 무시하고 서버 설정을 강제.
# PoC 환경에서 재발 방지를 우선한 선택 — 프로덕션에선 신중히.
skip-character-set-client-handshake
